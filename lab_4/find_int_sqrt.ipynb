    "N = 1025\n",
    "found_x = N\n",
    "while True:\n",
    "    new_x = (found_x + (N // found_x)) // 2\n",
    "\n",
    "    if new_x >= found_x:\n",
    "        break\n",
    "    found_x = new_x\n",
    "    # print(found_x)\n",
    "\n",
    "print(found_x)"
   ]
